---
import { getOutsideRouteParts } from "./_outsideRoutes.js";

// Mirrors every flat-shaped page under /web/** (e.g. web/about-polaris.md)
// at the root, producing a flat page.html — no trailing slash.
// Index-shaped pages (web/foo/index.astro) are handled by
// ./[...path]/index.astro instead, so they keep their folder/index.html shape.
export async function getStaticPaths() {
  const { flat } = getOutsideRouteParts();
  return flat.map((path) => ({ params: { path } }));
}

const { path } = Astro.params;
Astro.locals.outsidePath = path;
return Astro.rewrite(import.meta.env.BASE_URL);
---
